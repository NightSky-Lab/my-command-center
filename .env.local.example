# ==========================================================================
# MyPI Command Center — Environment Variables
# Salin fail ini kepada `.env.local` dan isi nilai dari projek Supabase anda.
# (Supabase Dashboard → Project Settings → API)
# ==========================================================================

# URL projek Supabase, cth: https://abcdefgh.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Kunci "anon / public" (selamat didedahkan ke pelayar)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# (Pilihan) Kunci "service_role" — HANYA untuk operasi pelayan / admin.
# JANGAN sekali-kali dedahkan kunci ini ke pelayar atau commit ke git.
SUPABASE_SERVICE_ROLE_KEY=
